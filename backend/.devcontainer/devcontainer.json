{
  "name": "ts-container", // Name of the container
  "image": "node:20", // Base image for the container
  "workspaceFolder": "/app", // Path to the workspace folder inside the container
  "mounts": [
    //bind mount
    "source=${localWorkspaceFolder},target=/app,type=bind",
    //name vloumes
    "source=ts-docker-logges,target=/app/logs,type=volume",
    //anonymous volume
    "target=/app/node_modules,type=volume"
  ],
  "runArgs": ["--name", "ts-container", "--rm", "--env-file=/.env"], // Additional arguments for running the container
  "postCreateCommand": "npm install"
}

